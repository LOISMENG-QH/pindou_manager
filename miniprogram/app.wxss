/**app.wxss**/
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* 通用按钮样式 */
.btn {
  padding: 24rpx 48rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-primary {
  background: #3b82f6;
  color: white;
}

.btn-secondary {
  background: #f3f4f6;
  color: #374151;
}

.btn-danger {
  background: #ef4444;
  color: white;
}

/* 卡片样式 */
.card {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

/* 输入框样式 */
.input {
  width: 100%;
  padding: 24rpx 32rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 32rpx;
}

.input:focus {
  border-color: #3b82f6;
}

/* 标题样式 */
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #111827;
}

.subtitle {
  font-size: 28rpx;
  color: #6b7280;
}

/* 列表样式 */
.list-item {
  background: white;
  padding: 32rpx;
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

/* 加载样式 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
  color: #9ca3af;
}

/* 空状态样式 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
  color: #9ca3af;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
}
