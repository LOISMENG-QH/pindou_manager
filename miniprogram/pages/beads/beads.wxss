/* pages/beads/beads.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 100rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  padding: 24rpx;
  background: white;
  gap: 16rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.search-input {
  flex: 1;
  padding: 20rpx 32rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.add-btn {
  padding: 20rpx 40rpx;
  background: #3b82f6;
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 豆子列表 */
.beads-list {
  padding: 24rpx;
}

.bead-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  position: relative;
}

.bead-card.low-stock {
  border: 3rpx solid #f59e0b;
}

/* 颜色块 */
.color-block {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  border: 2rpx solid #e5e7eb;
}

/* 豆子信息 */
.bead-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.bead-code {
  font-size: 32rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 8rpx;
}

.bead-name {
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.bead-quantity {
  font-size: 24rpx;
  color: #9ca3af;
}

.low-stock-badge {
  display: inline-block;
  margin-top: 8rpx;
  padding: 4rpx 12rpx;
  background: #fef3c7;
  color: #d97706;
  border-radius: 8rpx;
  font-size: 20rpx;
  width: fit-content;
}

/* 操作按钮 */
.bead-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.quantity-controls {
  display: flex;
  gap: 8rpx;
}

.quantity-btn {
  padding: 12rpx 16rpx;
  background: #f3f4f6;
  color: #374151;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
  min-width: 80rpx;
}

.edit-controls {
  display: flex;
  gap: 8rpx;
}

.edit-btn, .delete-btn {
  padding: 12rpx 20rpx;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.edit-btn {
  background: #3b82f6;
  color: white;
}

.delete-btn {
  background: #ef4444;
  color: white;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.modal-content {
  position: relative;
  width: 90%;
  max-width: 600rpx;
  background: white;
  border-radius: 24rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #111827;
}

.modal-close {
  font-size: 48rpx;
  color: #9ca3af;
  line-height: 1;
}

/* 表单 */
.form {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  padding: 24rpx 32rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 预设色号 */
.preset-colors {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.preset-color {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #e5e7eb;
  position: relative;
}

.preset-code {
  font-size: 24rpx;
  font-weight: bold;
  color: #111;
  background: rgba(255,255,255,0.8);
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
}

.submit-btn {
  width: 100%;
  padding: 28rpx;
  background: #3b82f6;
  color: white;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 32rpx;
}
