/* pages/patterns/patterns.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 100rpx;
}

/* 标签 */
.tabs {
  display: flex;
  background: white;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.tab {
  flex: 1;
  padding: 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #6b7280;
  border-bottom: 4rpx solid transparent;
}

.tab.active {
  color: #3b82f6;
  font-weight: bold;
  border-bottom-color: #3b82f6;
}

/* 悬浮添加按钮 */
.add-fab {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: #3b82f6;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  box-shadow: 0 8rpx 24rpx rgba(59,130,246,0.4);
  z-index: 100;
}

/* 图纸网格 */
.patterns-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 24rpx;
}

.pattern-card {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  position: relative;
}

.pattern-image {
  width: 100%;
  height: 300rpx;
  display: block;
}

.pattern-info {
  padding: 24rpx;
}

.pattern-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pattern-desc {
  font-size: 24rpx;
  color: #9ca3af;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.completed-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: #10b981;
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: bold;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.modal-content {
  position: relative;
  width: 90%;
  max-width: 600rpx;
  background: white;
  border-radius: 24rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.detail-modal .modal-content {
  max-height: 85vh;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #111827;
}

.modal-close {
  font-size: 48rpx;
  color: #9ca3af;
  line-height: 1;
}

/* 表单 */
.form {
  padding: 32rpx;
}

.image-preview {
  width: 100%;
  height: 400rpx;
  margin-bottom: 24rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f3f4f6;
}

.image-preview image {
  width: 100%;
  height: 100%;
}

.choose-image-btn {
  width: 100%;
  padding: 28rpx;
  background: #f3f4f6;
  color: #374151;
  border: 2rpx dashed #9ca3af;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
}

.input, .textarea {
  width: 100%;
  padding: 24rpx 32rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  min-height: 150rpx;
}

.submit-btn {
  width: 100%;
  padding: 28rpx;
  background: #3b82f6;
  color: white;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 32rpx;
}

/* 详情 */
.detail-content {
  padding: 32rpx;
}

.detail-image {
  width: 100%;
  max-height: 600rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.detail-desc {
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.beads-used {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 16rpx;
}

.bead-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #f3f4f6;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.bead-code {
  font-size: 28rpx;
  font-weight: bold;
  color: #3b82f6;
  min-width: 80rpx;
}

.bead-name {
  flex: 1;
  font-size: 26rpx;
  color: #6b7280;
  margin: 0 16rpx;
}

.bead-qty {
  font-size: 26rpx;
  color: #9ca3af;
}

.detail-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.complete-btn {
  background: #10b981;
  color: white;
}

.delete-btn {
  background: #ef4444;
  color: white;
}
