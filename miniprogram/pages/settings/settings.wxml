<!-- pages/settings/settings.wxml -->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar">👤</view>
    <view class="user-info">
      <view class="username">{{user.username || '用户'}}</view>
      <view class="email">{{user.email}}</view>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-grid">
    <view class="stat-card">
      <view class="stat-value">{{stats.beadsCount}}</view>
      <view class="stat-label">豆子种类</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">{{stats.patternsCount}}</view>
      <view class="stat-label">图纸总数</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">{{stats.completedCount}}</view>
      <view class="stat-label">已完成</view>
    </view>
    <view class="stat-card alert" wx:if="{{stats.lowStockCount > 0}}">
      <view class="stat-value">{{stats.lowStockCount}}</view>
      <view class="stat-label">⚠️ 库存不足</view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="section">
    <view class="section-title">数据管理</view>
    
    <view class="menu-list">
      <view class="menu-item" bindtap="syncData">
        <view class="menu-icon">🔄</view>
        <view class="menu-text">同步数据</view>
        <view class="menu-arrow">›</view>
      </view>

      <view class="menu-item" bindtap="checkHealth">
        <view class="menu-icon">💚</view>
        <view class="menu-text">API 状态</view>
        <view class="menu-arrow">›</view>
      </view>

      <view class="menu-item" bindtap="clearCache">
        <view class="menu-icon">🗑️</view>
        <view class="menu-text">清空缓存</view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">关于</view>
    
    <view class="menu-list">
      <view class="menu-item" bindtap="showAbout">
        <view class="menu-icon">ℹ️</view>
        <view class="menu-text">关于拼豆豆</view>
        <view class="menu-arrow">›</view>
      </view>

      <view class="menu-item">
        <view class="menu-icon">📱</view>
        <view class="menu-text">版本号</view>
        <view class="menu-value">v1.0.0</view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <view class="footer-text">Made with ❤️ by LOISMENG-QH</view>
    <view class="footer-text">数据安全存储在云端</view>
  </view>
</view>
