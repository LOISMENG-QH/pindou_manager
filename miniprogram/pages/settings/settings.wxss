/* pages/settings/settings.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 100rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.user-info {
  flex: 1;
}

.username {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 8rpx;
}

.email {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.stat-card.alert {
  background: #fef3c7;
  border: 2rpx solid #f59e0b;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #3b82f6;
  margin-bottom: 8rpx;
}

.stat-card.alert .stat-value {
  color: #d97706;
}

.stat-label {
  font-size: 24rpx;
  color: #6b7280;
}

/* 分组 */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #6b7280;
  padding: 0 16rpx;
  margin-bottom: 16rpx;
}

/* 菜单列表 */
.menu-list {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #111827;
}

.menu-value {
  font-size: 28rpx;
  color: #9ca3af;
  margin-right: 16rpx;
}

.menu-arrow {
  font-size: 40rpx;
  color: #9ca3af;
  font-weight: 300;
}

/* 退出登录 */
.logout-section {
  margin: 48rpx 0;
}

.logout-btn {
  width: 100%;
  padding: 28rpx;
  background: white;
  color: #ef4444;
  border: 2rpx solid #ef4444;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 32rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #9ca3af;
  line-height: 1.8;
}
