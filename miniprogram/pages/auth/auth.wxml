<!-- pages/auth/auth.wxml -->
<view class="auth-container">
  <view class="auth-card">
    <view class="logo">🎨</view>
    <view class="app-name">拼豆豆</view>
    <view class="mode-title">{{ mode === 'login' ? '登录账号' : '注册账号' }}</view>

    <view class="form">
      <!-- 邮箱 -->
      <view class="form-item">
        <view class="label">邮箱</view>
        <input
          class="input"
          type="text"
          placeholder="your@email.com"
          value="{{email}}"
          bindinput="onEmailInput"
        />
      </view>

      <!-- 用户名 (仅注册时显示) -->
      <view class="form-item" wx:if="{{mode === 'register'}}">
        <view class="label">用户名</view>
        <input
          class="input"
          type="text"
          placeholder="你的名字"
          value="{{username}}"
          bindinput="onUsernameInput"
        />
      </view>

      <!-- 密码 -->
      <view class="form-item">
        <view class="label">密码</view>
        <input
          class="input"
          type="password"
          placeholder="至少6位"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
      </view>

      <!-- 错误提示 -->
      <view class="error" wx:if="{{error}}">
        {{error}}
      </view>

      <!-- 提交按钮 -->
      <button
        class="submit-btn"
        type="primary"
        loading="{{loading}}"
        bindtap="handleSubmit"
      >
        {{ loading ? '处理中...' : (mode === 'login' ? '登录' : '注册') }}
      </button>
    </view>

    <!-- 切换模式 -->
    <view class="switch-mode">
      <text>{{ mode === 'login' ? '还没有账号？' : '已有账号？' }}</text>
      <text class="link" bindtap="switchMode">
        {{ mode === 'login' ? '立即注册' : '去登录' }}
      </text>
    </view>

    <!-- 提示 -->
    <view class="tip">
      <view>💡 提示：使用云端账号可以在多设备同步数据</view>
      <view>数据安全存储在你的服务器上</view>
    </view>
  </view>
</view>
